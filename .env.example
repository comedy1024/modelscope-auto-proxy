# ModelScope API 配置（注意：需要包含 ms- 前缀）
MODELSCOPE_API_KEY=ms-your_api_key_here

# 代理服务监听端口（如果 8000 被占用，修改此值，如 8001、9000 等）
PROXY_PORT=8000

# 代理服务对外暴露的模型名称（客户端用这个名字调用）
VIRTUAL_MODEL_NAME=modelscope-auto

# 模型参数量下限（B），只获取大于此值的文本模型
MIN_PARAM_B=4

# 模型刷新时间（秒），默认每天刷新一次
MODEL_REFRESH_INTERVAL=86400

# 日志级别
LOG_LEVEL=INFO

# 日志保留天数（0 表示永不清空，默认 30 天）
LOG_RETENTION_DAYS=30

# 管理后台登录凭证
# 如果 ADMIN_PASSWORD 为空，首次启动时会自动生成随机密码并写入此文件
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
